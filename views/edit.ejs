<%- include('partials/header') %>

<div class="container">
  <div class="app-header">
    <h1>✏️ Edit Task</h1>
  </div>

  <div class="add-card">
    <form action="/<%= todo._id %>?_method=PUT" method="POST" class="add-form">
      <div class="form-group">
        <label>Task Title *</label>
        <input type="text" name="title" value="<%= todo.title %>" required class="input-main">
      </div>
      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" value="<%= todo.description %>" class="input-desc" style="width:100%">
      </div>
      <div class="form-row form-extras">
        <div class="form-group" style="flex:1">
          <label>Priority</label>
          <select name="priority" class="select-priority" style="width:100%">
            <option value="low" <%= todo.priority === 'low' ? 'selected' : '' %>>🟢 Low</option>
            <option value="medium" <%= todo.priority === 'medium' ? 'selected' : '' %>>🟡 Medium</option>
            <option value="high" <%= todo.priority === 'high' ? 'selected' : '' %>>🔴 High</option>
          </select>
        </div>
        <div class="form-group" style="flex:1">
          <label>Due Date</label>
          <input type="date" name="dueDate" class="input-date" style="width:100%"
            value="<%= todo.dueDate ? new Date(todo.dueDate).toISOString().split('T')[0] : '' %>">
        </div>
      </div>
      <div class="form-row" style="gap:12px; margin-top:8px">
        <button type="submit" class="btn-add" style="flex:1">Save Changes</button>
        <a href="/" class="btn-cancel">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
